{
  "env": {
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash",
      "AskUserQuestion",
      "Task",
      "TaskCreate",
      "TaskGet",
      "TaskUpdate",
      "TaskList"
    ],
    "deny": [
      "Write(*.env)",
      "Write(*secrets*)",
      "Write(*.key)",
      "Write(*.pem)",
      "Write(*credentials*)",
      "Edit(*.env)",
      "Edit(*secrets*)",
      "Edit(*.key)",
      "Edit(*.pem)",
      "Edit(*credentials*)",
      "Bash(sudo*)",
      "Bash(*> /dev/)",
      "Bash(chmod 777*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-tool-use.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/fmflurry/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/prefer-code-memory.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notification.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/learning-user-prompt-submit.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "csharp-lsp@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true,
  "model": "claude-opus-4-8"
}
