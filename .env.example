# settings-opencode secrets template.
# Copy to .env (gitignored) and fill in, OR export these in your shell rc.
# NEVER commit real keys — only this template (names only) is tracked.

# Required only if you use the "myMistral" provider in opencode.jsonc:
MISTRAL_API_KEY=

# Other providers (anthropic / openai / github-copilot / opencode-go) need
# their own keys set the same way if you select their profiles.

# Learning loop (background learning extraction per idle window, not per message):
# - LEARNING_LOOP_IDLE_MS: milliseconds of inactivity before a review fires (default 300000 = 5 min)
# - LEARNING_LOOP_DAILY_CAP: max reviews per day across all sessions (default 50)
# - LEARNING_LOOP_BUDGET: max reviews per idle window per session (default 1)
# Uncomment and adjust if needed:
# LEARNING_LOOP_IDLE_MS=300000
# LEARNING_LOOP_DAILY_CAP=50
# LEARNING_LOOP_BUDGET=1
