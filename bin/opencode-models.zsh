# Mistral -> Medium
# mistral-medium-latest has NO reasoning support. opencode forwards each agent's
# reasoningEffort to the request body as reasoning_effort (keyed by providerID
# "mistral"). Any present value INCLUDING "none" is sent and rejected by the API
# ("reasoning_effort is not enabled for this model"). EMPTY string -> omitted -> OK.
# So the REASONING vars MUST be empty for this profile (verified via opencode run).
# export OPENCODE_MODEL_PRIMARY="mistral/mistral-medium-2604"
# export OPENCODE_MODEL_CONDUCTOR="mistral/mistral-medium-2604"
# export OPENCODE_MODEL_SUBAGENT_WORKER="mistral/mistral-medium-2604"
# export OPENCODE_MODEL_SUBAGENT_PLANNER="mistral/mistral-medium-2604"
